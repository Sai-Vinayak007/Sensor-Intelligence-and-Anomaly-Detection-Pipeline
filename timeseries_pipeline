    fig, ax = plt.subplots(figsize=(14, max(2, len(sensors))))
    _mv = df[sensors].isnull().values.T  
    _mv_df = pd.DataFrame(_mv, index=sensors, columns=df.index)
    heatmap_safe(_mv_df, ax=ax, cbar=False, cmap="Reds")
    ax.set_title("Missing Value Map (Red = Missing)")
    ax.set_xlabel("Time")
    plt.tight_layout()
    save_fig(out(cfg, "01_missing_value_map.png"), logger)

    fig, axes = plt.subplots(len(sensors), 1, figsize=(14, 3 * len(sensors)), sharex=True)
    axes = np.atleast_1d(axes)
    for i, col in enumerate(sensors):
        axes[i].plot(df.index, df[col], color="steelblue", linewidth=0.8)
        axes[i].set_ylabel(col)
        axes[i].set_title(f"{col} — Raw Signal")
    plt.suptitle("Raw Sensor Time Series", fontsize=14)
    plt.tight_layout()
    save_fig(out(cfg, "02_raw_time_series.png"), logger)

    fig, axes = plt.subplots(1, len(sensors), figsize=(5 * len(sensors), 4))
    axes = np.atleast_1d(axes)
    for i, col in enumerate(sensors):
        axes[i].hist(df[col].dropna(), bins=40, color="steelblue", edgecolor="white")
        axes[i].set_title(f"{col} Distribution")
        axes[i].set_xlabel("Value")
        axes[i].set_ylabel("Frequency")
    plt.suptitle("Raw Sensor Distributions", fontsize=14)
    plt.tight_layout()
    save_fig(out(cfg, "03_raw_distributions.png"), logger)

