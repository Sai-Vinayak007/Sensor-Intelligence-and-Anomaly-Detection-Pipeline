def setup_logging(output_dir: str, log_file: str) -> logging.Logger:
    os.makedirs(output_dir, exist_ok=True)
    log_path = os.path.join(output_dir, log_file)

    logger = logging.getLogger("ts_pipeline")
    logger.setLevel(logging.DEBUG)
    logger.handlers.clear()

    fmt = logging.Formatter("%(asctime)s [%(levelname)s] %(message)s",
                            datefmt="%Y-%m-%d %H:%M:%S")

    fh = logging.FileHandler(log_path, mode="a", encoding="utf-8")
    fh.setLevel(logging.DEBUG)
    fh.setFormatter(fmt)
    logger.addHandler(fh)

    ch = logging.StreamHandler(sys.stdout)
    ch.setLevel(logging.INFO)
    ch.setFormatter(fmt)
    logger.addHandler(ch)

    logger.info(f"Log file: {log_path}")
    return logger

def load_config(args) -> dict:
    cfg = DEFAULTS.copy()


    yaml_path = getattr(args, "config", "config.yaml")
    if YAML_AVAILABLE and yaml_path and Path(yaml_path).exists():
        with open(yaml_path) as f:
            yaml_cfg = yaml.safe_load(f) or {}
        cfg.update({k: v for k, v in yaml_cfg.items() if v is not None})


    if getattr(args, "csv", None):
        cfg["csv_path"] = args.csv
    if getattr(args, "output_dir", None):
        cfg["output_dir"] = args.output_dir
    if getattr(args, "time_col", None):
        cfg["time_col"] = args.time_col

    return cfg


def save_fig(path: str, logger: logging.Logger):
    if not os.path.exists(path):
        plt.savefig(path, dpi=150, bbox_inches="tight")
        logger.info(f"Saved: {path}")
    else:
        logger.info(f"Already exists, skipped: {path}")
    plt.close()


def out(cfg: dict, filename: str) -> str:
    return os.path.join(cfg["output_dir"], filename)


def section(title: str, logger: logging.Logger):
    logger.info("=" * 55)
    logger.info(f"  {title}")
    logger.info("=" * 55)


def assert_no_nans(df: pd.DataFrame, sensors: list, step: str, logger: logging.Logger):
    n = df[sensors].isnull().sum().sum()
    if n > 0:
        msg = f"[{step}] {n} NaN values remain — aborting to prevent silent ML failures."
        logger.error(msg)
        raise ValueError(msg)
    logger.debug(f"[{step}] NaN guard passed.")


def assert_shape(df: pd.DataFrame, min_rows: int, step: str, logger: logging.Logger):
    if len(df) < min_rows:
        msg = f"[{step}] Only {len(df)} rows after cleaning — need at least {min_rows}."
        logger.error(msg)
        raise ValueError(msg)
    logger.debug(f"[{step}] Shape guard passed: {df.shape}")


def flag_outliers_iqr(series: pd.Series, k: float = 3.0) -> pd.Series:
    Q1, Q3 = series.quantile(0.25), series.quantile(0.75)
    IQR = Q3 - Q1
    return (series < Q1 - k * IQR) | (series > Q3 + k * IQR)


def heatmap_safe(data: pd.DataFrame, ax=None, **kwargs):
    N_TICKS = 8

    kwargs["xticklabels"] = False      
    kwargs.setdefault("yticklabels", True)

    if ax is None:
        ax = plt.gca()

    sns.heatmap(data, ax=ax, **kwargs)

    n_cols   = data.shape[1]
    cols     = list(data.columns)
    n_ticks  = min(N_TICKS, n_cols)
    tick_idx = np.linspace(0, n_cols - 1, n_ticks, dtype=int)

    tick_labels = []
    for i in tick_idx:
        try:
            tick_labels.append(pd.Timestamp(cols[i]).strftime("%H:%M"))
        except Exception:
            tick_labels.append(str(cols[i])[:5])

    ax.set_xticks([i + 0.5 for i in tick_idx])
    ax.set_xticklabels(tick_labels, rotation=0, fontsize=8, ha="center")
    ax.tick_params(axis="x", length=0)   
    return ax

def load_data(cfg: dict, logger: logging.Logger) -> tuple[pd.DataFrame, list]:
    section("STEP 1: Load & Explore Data", logger)

    path = cfg["csv_path"]
    if not Path(path).exists():
        raise FileNotFoundError(f"CSV not found: {path}")

    df = pd.read_csv(path)
    df[cfg["time_col"]] = pd.to_datetime(df[cfg["time_col"]])
    df = df.sort_values(cfg["time_col"]).reset_index(drop=True)
    df = df.set_index(cfg["time_col"])

    sensors = cfg.get("sensors") or df.select_dtypes(include=[np.number]).columns.tolist()
    if not sensors:
        raise ValueError("No numeric columns found in the CSV.")
    logger.info(f"Sensors detected: {sensors}")

    logger.info(f"Shape       : {df.shape}")
    logger.info(f"Time range  : {df.index.min()} → {df.index.max()}")
    logger.info(f"Inferred freq: {df.index.inferred_freq}")
    logger.debug(f"\nData types:\n{df.dtypes}")
    logger.info(f"\nMissing values:\n{df[sensors].isnull().sum().to_string()}")
    logger.info(f"\nMissing (%):\n{(df[sensors].isnull().sum() / len(df) * 100).round(2).to_string()}")
    logger.info(f"\nDescriptive stats:\n{df[sensors].describe().round(4).to_string()}")

    return df, sensors

def plot_raw(df: pd.DataFrame, sensors: list, cfg: dict, logger: logging.Logger):
